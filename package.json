{
  "name": "pulse-vpn",
  "version": "0.1.0",
  "private": true,
  "license": "GPL-3.0-or-later",
  "main": "index.js",
  "scripts": {
    "start": "expo start --dev-client",
    "start:go": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "prebuild": "expo prebuild",
    "prebuild:ios": "expo prebuild -p ios && ruby scripts/install_packet_tunnel_target.rb",
    "build:android:apk": "bash scripts/build_android_local.sh",
    "build:ios:ipa": "bash scripts/build_ios_local.sh",
    "build:android:local": "npm run build:android:apk",
    "build:ios:local": "npm run build:ios:ipa",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/native": "^7.1.6",
    "expo": "~53.0.22",
    "expo-background-fetch": "~13.1.6",
    "expo-blur": "~14.1.5",
    "expo-build-properties": "~0.14.8",
    "expo-constants": "~17.1.7",
    "expo-device": "~7.1.4",
    "expo-haptics": "~14.1.4",
    "expo-linear-gradient": "~14.1.5",
    "expo-modules-core": "~2.5.0",
    "expo-status-bar": "~2.2.3",
    "expo-task-manager": "~13.1.6",
    "pulse-vpn-bridge": "file:modules/vpn-bridge",
    "react": "19.0.0",
    "react-native": "0.79.5",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1"
  },
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@types/node": "^22.15.3",
    "@types/react": "^19.0.12",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^9.25.1",
    "eslint-config-expo": "^9.2.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
